# 飞书应用凭证 - 从飞书开放平台获取
# 登录 https://open.feishu.cn/ -> 创建/选择应用 -> 凭证与基础信息
FEISHU_APP_ID=cli_xxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxx

# 事件订阅配置（可选，用于接收飞书事件回调）
# 在飞书开放平台 -> 事件订阅 -> 配置请求地址时会显示
FEISHU_VERIFICATION_TOKEN=xxxxxxxxxx
FEISHU_ENCRYPT_KEY=

# 多维表格配置 - 从你的飞书多维表格 URL 中获取
# URL 格式: https://xxx.feishu.cn/wiki/APPTOKEN?table=TABLEID
BITABLE_APP_TOKEN=appxxxxxxxxxx
INTERPRETATION_TABLE_ID=tblxxxxxxxxxx
TRANSLATION_TABLE_ID=tblxxxxxxxxxx

# 字段名配置 - 根据你多维表格中的实际字段名填写
STATUS_FIELD_NAME=承接进度
WORKHOUR_FIELD_NAME=工时统计/min
PROJECT_NAME_FIELD_NAME=项目名称

# 服务器配置
PORT=3000
NODE_ENV=development
