# ========================================
# 工时管理 Web 应用 - 后端环境变量配置
# ========================================
# 复制此文件为 .env 并填写实际值
# cp .env.example .env

# ---------- 飞书应用凭证 ----------
# 在飞书开放平台创建应用后获取
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret

# ---------- 飞书多维表格配置 ----------
# 多维表格 App Token
BITABLE_APP_TOKEN=LZxwwV9vGiHesHk5nEVcsw1Pnud
# 口译表 Table ID
INTERPRETATION_TABLE_ID=tblxCsMVGfag1mmZ
# 笔译表 Table ID
TRANSLATION_TABLE_ID=tbliA5bK8PsJ213l

# ---------- JWT 配置 ----------
# 用于签发和验证 JWT 令牌的密钥（请使用随机字符串）
JWT_SECRET=your_jwt_secret_here

# ---------- 服务配置 ----------
# 后端服务端口（默认 3002）
PORT=3002
# 允许的前端跨域来源
CORS_ORIGIN=http://localhost:5174

# ---------- 飞书 OAuth 回调 ----------
# 飞书 OAuth 授权回调地址（需与飞书开放平台配置一致）
FEISHU_REDIRECT_URI=http://localhost:5174/auth/callback
